{
  "name": "@indigo-lab/jx",
  "version": "0.0.1",
  "description": "JX is a JSON transform spec and a set of tools for minimalists",
  "keywords": [
    "JSON",
    "transform"
  ],
  "bin": {
    "jx": "bin/cli.js"
  },
  "homepage": "https://github.com/indigo-lab/jx#readme",
  "bugs": {
    "url": "https://github.com/indigo-lab/jx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/indigo-lab/jx.git"
  },
  "license": "MIT",
  "author": "indigo-lab",
  "type": "commonjs",
  "main": "jx.js",
  "scripts": {
    "test": "tape test/test-*.js",
    "prepare": "npm run build",
    "build": "npm run property-name-extension && npm run property-value-extension",
    "property-name-extension": "peggy --format commonjs spec/property-name-extension.pegjs -o lib/property-name-extension.js",
    "property-value-extension": "peggy --format commonjs spec/property-value-extension.pegjs -o lib/property-value-extension.js"
  },
  "dependencies": {
    "jsonpointer": "^5.0.1"
  },
  "devDependencies": {
    "peggy": "^5.1.0",
    "tape": "^5.9.0"
  }
}
